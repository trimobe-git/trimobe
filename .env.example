# WhatsApp do operador (formato internacional, somente dígitos)
# Exemplo Brasil: 5511999999999
NEXT_PUBLIC_WHATSAPP_NUMBER=5511999999999

# Telefone formatado para exibição na página (opcional, aparece no rodapé e no CTA final)
# Exemplo: (11) 99999-9999
NEXT_PUBLIC_PHONE_DISPLAY=(11) 99999-9999

# Google Tag Manager
# Obtenha seu GTM ID em: https://tagmanager.google.com/
# Formato: GTM-XXXXXXX
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
